#!/bin/bash

# ============================================
# Nervsys Module Manager (mm)
# ============================================

# Check PHP availability
if ! command -v php &> /dev/null; then
    echo "[ERROR] PHP not found in PATH."
    exit 1
fi

# Get script directory and manager.php path
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MANAGER_PHP="$SCRIPT_DIR/../modules/manager/bin/manager.php"

# Get current working directory (startup directory)
CWD="$(pwd)"

# First argument as command
COMMAND="$1"

# Help
if [ -z "$COMMAND" ] || [ "$COMMAND" = "help" ] || [ "$COMMAND" = "-h" ]; then
    echo ""
    echo "Nervsys Module Manager (mm)"
    echo ""
    echo "Usage:"
    echo "  mm [target_dir] install {user/repo}[@tag][#https/#git]"
    echo "  mm [target_dir] init {module_name}"
    echo "  mm [target_dir] set-remote {git_source}"
    echo "  mm help"
    echo ""
    echo "Examples:"
    echo "  mm modules install nervsys/logger"
    echo "  mm modules install nervsys/logger@v1.0.0"
    echo "  mm modules install nervsys/logger@v1.0.0#git"
    echo "  mm custom init my_module"
    echo "  mm any_dir set-remote gitee.com"
    echo ""
    exit 0
fi

# Pass all arguments and append CWD as last argument
php "$MANAGER_PHP" "$@" "$CWD"
exit $?