#!/bin/bash

# ============================================
# Nervsys Module Manager (mm)
# ============================================

# Check PHP availability
if ! command -v php &> /dev/null; then
    echo "[ERROR] PHP not found in PATH."
    exit 1
fi

# Get script directory and manager.php path
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MANAGER_PHP="$SCRIPT_DIR/../modules/manager/bin/manager.php"

# Get current working directory (startup directory)
CWD="$(pwd)"

# First argument as command
COMMAND="$1"

# Help
if [ -z "$COMMAND" ] || [ "$COMMAND" = "help" ] || [ "$COMMAND" = "-h" ]; then
    echo ""
    echo "Nervsys Module Manager (mm)"
    echo ""
    echo "Usage:"
    echo "  mm install {user/repo}[@tag][@https/@git] [target_dir]"
    echo "  mm init {module_name} [target_dir]"
    echo "  mm setRemote {git_source}"
    echo "  mm help"
    echo ""
    echo "Examples:"
    echo "  mm install nervsys/logger"
    echo "  mm install nervsys/logger@v1.0.0"
    echo "  mm install nervsys/logger@v1.0.0@git"
    echo "  mm init my_module"
    echo "  mm init my_module custom_modules"
    echo "  mm setRemote gitee.com"
    echo ""
    exit 0
fi

# Pass all arguments and append CWD as last argument
php "$MANAGER_PHP" "$@" "$CWD"
exit $?